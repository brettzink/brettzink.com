---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Brett Zink | Engineering Leader">
  <section class="hero">
    <h1>Brett Zink</h1>
    <p class="tagline">Engineering Leader | Cloud Infrastructure &amp; Security</p>
    <p class="intro">
      I've spent my career at the intersection of security, infrastructure,
      and software. I started in banking security, moved into full-stack
      development and DevOps, and now lead cyber security and infrastructure
      at Matrix Pointe Software.
    </p>
    <img src="/terminal-hero.svg" alt="Terminal showing career summary" class="terminal-hero" />
  </section>
</BaseLayout>
